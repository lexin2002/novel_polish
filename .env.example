# Novel Polish 环境变量配置
# 注意：LLM 提供商配置（API Key、Base URL、模型等）通过 config.jsonc 管理，
#       在应用启动后通过 UI 的"系统设置"侧边栏配置。
#       配置文件位置：Linux/macOS: ~/.config/NovelPolish/config.jsonc
#                      Windows: %APPDATA%/NovelPolish/config.jsonc
#       此 .env 文件仅用于 Electron 应用的启动参数。

# ==================== 后端启动参数 ====================
# 后端端口（默认 57621）
PORT=57621

# 后端监听地址（默认 localhost）
HOST=localhost

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO
